# Estándares de TypeScript 2026

## Configuración Básica

### tsconfig.json

Siempre habilitar modo estricto para máxima seguridad de tipos:

```json
{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
```

## Type Safety

### Minimizar uso de `any`

```typescript
// ❌ Evitar
function processData(data: any) {
  return data.value;
}

// ✅ Correcto - Usar tipos específicos
function processData(data: UserData) {
  return data.value;
}

// ✅ Correcto - Usar unknown cuando el tipo es desconocido
function processData(data: unknown) {
  if (typeof data === 'object' && data !== null && 'value' in data) {
    return (data as { value: string }).value;
  }
  throw new TypeError('Invalid data format');
}
```

### Strict Type-Checking

```typescript
// ✅ Usar tipos estrictos
function getUserName(user: User): string {
  return user.name;
}

// ✅ Manejar null/undefined explícitamente
function getUserEmail(user: User | null): string | null {
  return user?.email ?? null;
}

// ✅ Usar never para casos imposibles
function assertNever(value: never): never {
  throw new Error(`Unexpected value: ${value}`);
}
```

## Naming Conventions

```typescript
// ✅ camelCase para variables y funciones
const userName = 'John';
const userAge = 30;
function getUserData() { /* ... */ }

// ✅ PascalCase para clases, interfaces, types, enums
class UserService { /* ... */ }
interface UserData { /* ... */ }
type UserId = string;
enum UserRole { Admin, User, Guest }

// ✅ UPPER_SNAKE_CASE para constantes globales
const MAX_RETRY_ATTEMPTS = 3;
const API_BASE_URL = '/api';
```

## Type Inference vs Explicit Annotations

```typescript
// ✅ Inferencia para asignaciones obvias
const count = 42; // TypeScript infiere number
const items = [1, 2, 3]; // TypeScript infiere number[]

// ✅ Anotaciones explícitas para APIs públicas
export function processUser(user: User): ProcessedUser {
  // ...
}

// ✅ Anotaciones para estructuras complejas
const config: AppConfig = {
  timeout: 5000,
  retries: 3,
  endpoints: {
    api: '/api',
    auth: '/auth'
  }
};
```

## Organización de Código

### Un Concepto por Archivo

```typescript
// ✅ user-types.ts - Solo tipos de usuario
export interface User {
  id: string;
  name: string;
  email: string;
}

export type UserId = string;

// ✅ user-service.ts - Solo lógica de servicio
import { User, UserId } from './user-types';

export class UserService {
  async getUser(id: UserId): Promise<User> {
    // ...
  }
}

// ❌ Evitar archivos genéricos como helpers.ts o utils.ts
// En su lugar, usar nombres específicos como date-helpers.ts, string-utils.ts
```

## Immutability

```typescript
// ✅ Usar const por defecto
const user = { name: 'John', age: 30 };

// ✅ Usar readonly para propiedades inmutables
interface User {
  readonly id: string;
  readonly createdAt: Date;
  name: string;
}

// ✅ Usar ReadonlyArray o readonly modifier
function processItems(items: readonly string[]): void {
  // items.push('new'); // Error: no se puede mutar
  const newItems = [...items, 'new']; // ✅ Crear nuevo array
}

// ✅ Usar as const para literales
const config = {
  apiUrl: '/api',
  timeout: 5000
} as const;
```

## Composition over Inheritance

```typescript
// ✅ Preferir composición
interface Loggable {
  log(message: string): void;
}

interface Cacheable {
  cache: Map<string, unknown>;
  getCached<T>(key: string): T | undefined;
}

class UserService implements Loggable, Cacheable {
  cache = new Map<string, unknown>();
  
  log(message: string): void {
    console.log(`[UserService] ${message}`);
  }
  
  getCached<T>(key: string): T | undefined {
    return this.cache.get(key) as T | undefined;
  }
}

// ❌ Evitar jerarquías profundas de herencia
class BaseService { /* ... */ }
class ExtendedService extends BaseService { /* ... */ }
class MoreExtendedService extends ExtendedService { /* ... */ } // NO
```

## Enums y Union Types

```typescript
// ✅ Enums para conjuntos de constantes nombradas
enum UserRole {
  Admin = 'ADMIN',
  User = 'USER',
  Guest = 'GUEST'
}

// ✅ Union types para estados
type LoadingState = 
  | { status: 'idle' }
  | { status: 'loading' }
  | { status: 'success'; data: User }
  | { status: 'error'; error: Error };

function handleState(state: LoadingState) {
  switch (state.status) {
    case 'idle':
      return 'Waiting...';
    case 'loading':
      return 'Loading...';
    case 'success':
      return `Loaded: ${state.data.name}`;
    case 'error':
      return `Error: ${state.error.message}`;
  }
}
```

## Null Safety

```typescript
// ✅ Usar optional chaining
const userName = user?.profile?.name;

// ✅ Usar nullish coalescing
const displayName = userName ?? 'Guest';

// ✅ Definir tipos que excluyen null/undefined cuando sea apropiado
function processUser(user: User): void {
  // user nunca es null/undefined aquí
}

// ✅ Usar NonNullable utility type
type UserId = NonNullable<User['id']>;
```

## Error Handling

```typescript
// ✅ Try-catch con tipos de error
async function fetchUser(id: string): Promise<User> {
  try {
    const response = await fetch(`/api/users/${id}`);
    if (!response.ok) {
      throw new Error(`HTTP error! status: ${response.status}`);
    }
    return await response.json();
  } catch (error) {
    if (error instanceof Error) {
      console.error('Failed to fetch user:', error.message);
    }
    throw error;
  }
}

// ✅ Tipos de error personalizados
class UserNotFoundError extends Error {
  constructor(public userId: string) {
    super(`User not found: ${userId}`);
    this.name = 'UserNotFoundError';
  }
}

function getUser(id: string): User {
  const user = users.find(u => u.id === id);
  if (!user) {
    throw new UserNotFoundError(id);
  }
  return user;
}
```

## Generics

```typescript
// ✅ Usar generics para código reutilizable
function identity<T>(value: T): T {
  return value;
}

// ✅ Generics con constraints
function getProperty<T, K extends keyof T>(obj: T, key: K): T[K] {
  return obj[key];
}

// ✅ Generics en interfaces
interface Repository<T> {
  getById(id: string): Promise<T>;
  save(item: T): Promise<void>;
  delete(id: string): Promise<void>;
}

class UserRepository implements Repository<User> {
  async getById(id: string): Promise<User> { /* ... */ }
  async save(user: User): Promise<void> { /* ... */ }
  async delete(id: string): Promise<void> { /* ... */ }
}
```

## Utility Types

```typescript
// ✅ Usar utility types integrados
type PartialUser = Partial<User>; // Todas las propiedades opcionales
type RequiredUser = Required<User>; // Todas las propiedades requeridas
type UserKeys = keyof User; // 'id' | 'name' | 'email'
type UserName = Pick<User, 'name'>; // { name: string }
type UserWithoutEmail = Omit<User, 'email'>; // { id: string; name: string }
type ReadonlyUser = Readonly<User>; // Todas las propiedades readonly

// ✅ Crear utility types personalizados
type Nullable<T> = T | null;
type Optional<T> = T | undefined;
type AsyncReturnType<T extends (...args: any) => Promise<any>> = 
  T extends (...args: any) => Promise<infer R> ? R : never;
```

