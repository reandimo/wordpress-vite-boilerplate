        'menu_class' => 'nav-menu',
        'items_wrap' => '<ul class="%2$s">%3$s</ul>',
    ]);
    ?>
  </nav>
</header>

<!-- ✅ templates/index.html -->
<main id="main-content" role="main">
  <?php
  if (have_posts()) {
      while (have_posts()) {
          the_post();
          get_template_part('parts/content', get_post_type());
      }
  }
  ?>
</main>
```

### Breadcrumbs Accesibles

```php
// ✅ Función para breadcrumbs accesibles
function get_accessible_breadcrumbs(): string {
    $items = [];
    $items[] = '<li><a href="' . esc_url(home_url('/')) . '">' . esc_html__('Inicio', 'textdomain') . '</a></li>';
    
    if (is_single()) {
        $items[] = '<li><a href="' . esc_url(get_permalink(get_option('page_for_posts'))) . '">' . esc_html__('Blog', 'textdomain') . '</a></li>';
        $items[] = '<li aria-current="page">' . esc_html(get_the_title()) . '</li>';
    }
    
    return '<nav aria-label="' . esc_attr__('Breadcrumb', 'textdomain') . '">
        <ol class="breadcrumb">' . implode('', $items) . '</ol>
    </nav>';
}
```

## Testing de Accesibilidad

### Herramientas Recomendadas

```bash
# Lighthouse (Chrome DevTools)
# - Ejecutar auditoría de accesibilidad
# - Puntuación objetivo: 100/100

# WAVE (Web Accessibility Evaluation Tool)
# - Extensión de navegador
# - Identifica problemas de accesibilidad

# axe DevTools
# - Extensión de navegador
# - Análisis automático de accesibilidad

# Pa11y
npm install -g pa11y
pa11y https://example.com

# ESLint con eslint-plugin-jsx-a11y
npm install --save-dev eslint-plugin-jsx-a11y
```

### Checklist de Accesibilidad

- [ ] Todos los elementos interactivos son accesibles por teclado
- [ ] Todos los elementos tienen indicadores de focus visibles
- [ ] Todas las imágenes tienen texto alternativo apropiado
- [ ] El contraste de colores cumple con WCAG AA (4.5:1 para texto normal)
- [ ] Los formularios tienen labels asociados
- [ ] Los mensajes de error son descriptivos y accesibles
- [ ] La estructura semántica HTML es correcta (h1-h6, landmarks)
- [ ] ARIA se usa correctamente cuando es necesario
- [ ] Las animaciones respetan prefers-reduced-motion
- [ ] El sitio es navegable solo con teclado
- [ ] Los screen readers pueden leer todo el contenido importante
- [ ] No hay dependencia exclusiva del color para transmitir información

