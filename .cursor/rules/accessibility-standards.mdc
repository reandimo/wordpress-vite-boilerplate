## Formularios Accesibles

### Labels y Asociaciones

```html
<!-- ✅ Label explícito -->
<label for="email">Correo electrónico</label>
<input 
  type="email" 
  id="email" 
  name="email" 
  required
  aria-required="true"
>

<!-- ✅ Label implícito -->
<label>
  Nombre completo
  <input type="text" name="name" required>
</label>

<!-- ✅ aria-label cuando no hay label visible -->
<input 
  type="search" 
  aria-label="Buscar productos"
  placeholder="Buscar..."
>

<!-- ✅ aria-describedby para ayuda -->
<label for="password">Contraseña</label>
<input 
  type="password" 
  id="password" 
  name="password"
  aria-describedby="password-help password-requirements"
  required
>
<span id="password-help" class="help-text">
  La contraseña debe tener al menos 8 caracteres
</span>
<ul id="password-requirements" class="sr-only">
  <li>Mínimo 8 caracteres</li>
  <li>Al menos una mayúscula</li>
  <li>Al menos un número</li>
</ul>
```

### Mensajes de Error

```html
<!-- ✅ Errores asociados con aria-describedby -->
<label for="email">Correo electrónico</label>
<input 
  type="email" 
  id="email" 
  name="email"
  aria-invalid="true"
  aria-describedby="email-error"
  required
>
<span id="email-error" role="alert" class="error-message">
  Por favor ingrese un correo electrónico válido
</span>

<!-- ✅ JavaScript para actualizar estados -->
function validateEmail(input) {
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const isValid = emailRegex.test(input.value);
  
  if (!isValid) {
    input.setAttribute('aria-invalid', 'true');
    input.setAttribute('aria-describedby', 'email-error');
  } else {
    input.removeAttribute('aria-invalid');
    input.removeAttribute('aria-describedby');
  }
  
  return isValid;
}
```

