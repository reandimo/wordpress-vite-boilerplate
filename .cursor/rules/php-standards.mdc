## Performance Optimization

```php
// ✅ Usar OPcache en producción (php.ini)
opcache.enable=1
opcache.memory_consumption=128
opcache.interned_strings_buffer=8
opcache.max_accelerated_files=10000
opcache.validate_timestamps=0  // En producción

// ✅ Usar caching
function get_user_data(int $user_id): array {
    $cache_key = "user_data_{$user_id}";
    $data = wp_cache_get($cache_key);

    if (false === $data) {
        $data = expensive_database_query($user_id);
        wp_cache_set($cache_key, $data, '', 3600);
    }

    return $data;
}

// ✅ Usar transients para datos que cambian poco
function get_popular_posts(): array {
    $posts = get_transient('popular_posts');
    
    if (false === $posts) {
        $posts = expensive_query_for_popular_posts();
        set_transient('popular_posts', $posts, DAY_IN_SECONDS);
    }
    
    return $posts;
}
```

## Testing

```php
// ✅ Usar PHPUnit para testing
use PHPUnit\Framework\TestCase;

class UserServiceTest extends TestCase {
    private UserService $service;
    
    protected function setUp(): void {
        $this->service = new UserService(
            $this->createMock(DatabaseConnection::class),
            $this->createMock(LoggerInterface::class),
            $this->createMock(CacheInterface::class)
        );
    }
    
    public function test_get_user_returns_user(): void {
        $user = $this->service->getUser(1);
        
        $this->assertInstanceOf(User::class, $user);
        $this->assertEquals('John', $user->getName());
    }
    
    public function test_get_user_throws_exception_when_not_found(): void {
        $this->expectException(UserNotFoundException::class);
        $this->service->getUser(999);
    }
}
```

