### Hooks y Filters

```php
// ✅ Usar prefijos del tema (ej: __THEME_SLUG__)
add_action('init', '__THEME_SLUG___init');
add_filter('the_content', '__THEME_SLUG___modify_content');

// ✅ Usar closures cuando sea apropiado
add_action('wp_enqueue_scripts', function(): void {
    wp_enqueue_style('__THEME_SLUG__-style', get_stylesheet_uri(), [], THEME_VERSION);
    wp_enqueue_script('__THEME_SLUG__-script', THEME_URI . '/public/js/main.js', [], THEME_VERSION, true);
});

// ✅ Usar clases para organizar hooks
class ThemeSetup {
    public function __construct() {
        add_action('after_setup_theme', $this->setupTheme(...));
        add_action('wp_enqueue_scripts', $this->enqueueAssets(...));
    }
    
    private function setupTheme(): void {
        add_theme_support('post-thumbnails');
        add_theme_support('title-tag');
        register_nav_menus([
            'primary' => __('Primary Menu', '__THEME_SLUG__'),
            'footer' => __('Footer Menu', '__THEME_SLUG__'),
        ]);
    }
    
    private function enqueueAssets(): void {
        wp_enqueue_style('__THEME_SLUG__-style', get_stylesheet_uri(), [], THEME_VERSION);
    }
}

new ThemeSetup();
```

