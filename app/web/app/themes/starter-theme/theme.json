{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1440px"
    },
    "color": {
      "palette": [
        { "slug": "primary", "color": "#0066cc", "name": "Primary" },
        { "slug": "secondary", "color": "#333333", "name": "Secondary" },
        { "slug": "accent", "color": "#e63946", "name": "Accent" },
        { "slug": "white", "color": "#ffffff", "name": "White" },
        { "slug": "light", "color": "#f8f9fa", "name": "Light" },
        { "slug": "dark", "color": "#212529", "name": "Dark" },
        { "slug": "muted", "color": "#6c757d", "name": "Muted" },
        { "slug": "border", "color": "#dee2e6", "name": "Border" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
          "slug": "system-sans",
          "name": "System Sans"
        },
        {
          "fontFamily": "Georgia, 'Times New Roman', Times, serif",
          "slug": "system-serif",
          "name": "System Serif"
        },
        {
          "fontFamily": "ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, 'DejaVu Sans Mono', monospace",
          "slug": "system-mono",
          "name": "System Mono"
        }
      ],
      "fontSizes": [
        { "size": "0.875rem", "slug": "small", "name": "Small" },
        { "size": "1rem", "slug": "medium", "name": "Medium" },
        { "size": "1.125rem", "slug": "large", "name": "Large" },
        { "size": "1.5rem", "slug": "x-large", "name": "Extra Large" },
        { "size": "2rem", "slug": "xx-large", "name": "2X Large" },
        { "size": "2.5rem", "slug": "huge", "name": "Huge" }
      ]
    },
    "spacing": {
      "units": ["%", "px", "em", "rem", "vh", "vw"]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--dark)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-sans)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "fontWeight": "400",
      "lineHeight": "1.7"
    },
    "elements": {
      "link": {
        "color": { "text": "var(--wp--preset--color--primary)" },
        "typography": { "textDecoration": "underline" }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--huge)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xx-large)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--x-large)",
          "fontWeight": "600",
          "lineHeight": "1.3"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--large)",
          "fontWeight": "600",
          "lineHeight": "1.4"
        }
      },
      "button": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--medium)",
          "fontWeight": "500"
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--white)"
        },
        "border": {
          "radius": "6px"
        }
      }
    },
    "spacing": { "blockGap": "1.5rem" }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
