# =============================================================================
# Docker — Variables for docker-compose (MariaDB, etc.)
# =============================================================================
DB_ROOT_PASSWORD=root
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=wordpress

# =============================================================================
# Remote Sync (wp-sync) — Only needed if using remote-sync or both dev modes
# =============================================================================

# Paths
LOCAL_PATH=./app/web/app/themes/__THEME_SLUG__
REMOTE_PATH=/var/www/html/wp-content/themes/__THEME_SLUG__

# Protocol: ssh or ftp
SYNC_PROTOCOL=ssh

# Server connection
REMOTE_USER=
REMOTE_HOST=
REMOTE_PORT=22

# FTP only (when SYNC_PROTOCOL=ftp)
REMOTE_PASSWORD=

# Sync behavior
SYNC_EXCLUDE=.git,node_modules,.DS_Store,*.log,.env,public/hot
SYNC_DELETE=false

# Tunnel (optional)
# TUNNEL_TOOL=cloudflared
# TUNNEL_DOMAIN=mi-sitio.com
